# Gold Macro Engine — exemple de configuration. Copier en .env et remplir.
# (le vrai .env est gitignoré — ne JAMAIS committer de secret)

# --- Sources de données ---
FRED_API_KEY=                 # REQUIS (gratuit : https://fred.stlouisfed.org/docs/api/api_key.html)
ANTHROPIC_API_KEY=            # optionnel : NLP Claude Haiku ; vide -> repli lexique
TRADE_DB_PATH=/data/trade.db  # prix XAU via candle_data du système trade (montage compose)

# --- Persistance ---
GOLD_MACRO_DB=/data/gold_macro.db

# --- Scheduler (cadences en secondes) ---
GOLD_MACRO_TICK_SECONDS=300   # évaluation toutes les 5 min
GOLD_MACRO_DIGEST_SECONDS=3600 # digest WARNING toutes les heures
GOLD_MACRO_NEWS_TTL=1800      # rafraîchissement news / Claude toutes les 30 min

# --- Garde-fou de coût Claude ---
COST_REPORT_EVERY_EUR=1.0     # rapport d'utilisation tous les 1 €
COST_HARD_STOP_EUR=10.0       # STOP dur à 10 € -> repli lexique

# --- Destination des alertes (priorité : Telegram > webhook > log) ---
TELEGRAM_BOT_TOKEN=           # bot Telegram pour pousser les alertes
TELEGRAM_CHAT_ID=             # chat/canal cible
ALERT_WEBHOOK_URL=            # sinon, webhook générique {"text": ...}

# --- Intégration TradingView (entrée : tes alertes Pine -> moteur) ---
TRADINGVIEW_WEBHOOK_SECRET=   # si renseigné, le webhook exige ce secret dans le JSON
# Dashboard web : GET / (cockpit React) ; webhook Pine : POST /tradingview/webhook

# --- Calendrier économique (alertes pré-news) ---
# Dates de décision FOMC (pas dans FRED) — à ajuster, séparées par des virgules :
GOLD_MACRO_FOMC_DATES=2026-07-29,2026-09-16,2026-10-28,2026-12-16
